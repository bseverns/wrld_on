{
  "osc": {
    "host": "127.0.0.1",
    "port": 8000,
    "listenHost": "0.0.0.0",
    "listenPort": 8001,
    "logInbound": false
  },
  "interop": {
    "profilePath": "interop/exports/live-rig.default.json"
  },
  "commands": {
    "blackout": { "address": "/nw_wrld/blackout/enable", "on": [1], "off": [0] },
    "feed": { "address": "/nw_wrld/feed/enable", "on": [1], "off": [0] },
    "overlays": { "address": "/nw_wrld/overlays/enable", "on": [1], "off": [0] }
  },
  "semanticBindings": {
    "scene.intro": {
      "kind": "scene",
      "addresses": ["/video/scene/intro"],
      "stateOn": { "blackout": false, "feed": true, "overlays": true }
    },
    "scene.crash": {
      "kind": "scene",
      "addresses": ["/video/scene/crash"],
      "stateOn": { "blackout": false, "feed": true, "overlays": true }
    },
    "scene.soft": {
      "kind": "scene",
      "addresses": ["/video/scene/soft"],
      "stateOn": { "blackout": false, "feed": true, "overlays": false }
    },
    "scene.clean_camera": {
      "kind": "scene",
      "addresses": ["/video/scene/clean_camera"],
      "stateOn": { "blackout": false, "feed": true, "overlays": false }
    },
    "state.blackout": {
      "kind": "command",
      "addresses": ["/rig/state/blackout"],
      "command": "blackout",
      "onValue": 1,
      "offValue": 0
    }
  },
  "startup": {
    "apply": true,
    "delayMs": 0,
    "force": true,
    "state": { "blackout": true, "feed": false, "overlays": false }
  },
  "watchdog": {
    "enabled": true,
    "timeoutSec": 10,
    "checkIntervalMs": 500,
    "fadeMs": 0,
    "recoverOnActivity": false,
    "safeState": { "blackout": true, "feed": false, "overlays": false }
  },
  "panic": {
    "enabled": true,
    "hotkey": "p",
    "safeState": { "blackout": true, "feed": false, "overlays": false },
    "exitAfter": false
  },
  "health": {
    "logIntervalSec": 10,
    "httpPort": 8181,
    "fpsAddress": "/nw_wrld/health/fps"
  },
  "state": {
    "subscriptions": {
      "blackout": "/nw_wrld/blackout/state",
      "feed": "/nw_wrld/feed/state",
      "overlays": "/nw_wrld/overlays/state"
    }
  }
}
